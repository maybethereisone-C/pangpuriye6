# Backend API base URL.
# Copy this file to `.env.local` and fill in the real URL.
# .env.local is gitignored — your real URL stays out of the public repo.
NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com/api/v1/your-house

# Hostname only — used by next.config.ts to allow-list remote images.
NEXT_PUBLIC_API_HOSTNAME=your-backend.example.com

# Bearer token, if your backend requires auth. Leave blank otherwise.
API_AUTH_HEADER=Authorization
API_AUTH_VALUE=
